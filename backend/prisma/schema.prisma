generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum OtpPurpose {
  SIGNUP
  LOGIN
}

model User {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  phone       String   @unique
  username    String?  @unique

  isVerified  Boolean  @default(false)

  signupCompleted Boolean @default(false)

  refreshTokens RefreshToken[]

  @@index([createdAt])
}

model OtpRequest {
  id          String     @id @default(uuid())
  createdAt   DateTime   @default(now())

  phone       String
  purpose     OtpPurpose @default(SIGNUP)

  codeHash    String

  expiresAt   DateTime
  consumedAt  DateTime?

  attempts    Int        @default(0)
  maxAttempts Int        @default(5)

  ip          String?
  userAgent   String?

  @@index([phone, createdAt])
  @@index([expiresAt])
}

model RefreshToken {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId])
  @@index([expiresAt])
}
